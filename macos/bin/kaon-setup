#!/bin/zsh
# Source-tree launcher for Kaon's macOS setup engine.
set -eu

readonly script_dir="${0:A:h}"
readonly repository_root="${script_dir:h:h}"

if [[ -n "${KAON_PYTHON:-}" ]]; then
    python="$KAON_PYTHON"
elif command -v python3 >/dev/null 2>&1; then
    python="$(command -v python3)"
else
    print -u2 -- "Kaon setup needs Python 3 when run from source."
    print -u2 -- "Download the self-contained Kaon Setup.app release instead."
    exit 69
fi

exec "$python" "$repository_root/macos/engine/kaon_setup.py" "$@"
